# DRG-BR Platform — copie para .env e ajuste
# Desenvolvimento: FLASK_ENV=development
# Produção: FLASK_ENV=production e defina SECRET_KEY, JWT_SECRET_KEY, DATABASE_URL, CORS_ORIGINS

FLASK_ENV=development
SECRET_KEY=dev-secret-change-in-production
JWT_SECRET_KEY=dev-jwt-secret

# MySQL (obrigatório em produção)
DATABASE_URL=mysql+pymysql://root:12345678@localhost:3306/drg_br

# Produção: defina a origem do frontend (ex: https://app.seudominio.com)
# CORS_ORIGINS=https://app.seudominio.com

# DRG-BR pipeline
DRG_DB_PATH=data/drg_br.db
DRG_MODEL_DIR=models
DRG_CACHE_DIR=data/cache

# Opcional
# PORT=5001
# JWT_ACCESS_TOKEN_EXPIRES=86400
# FLASK_DEBUG=0
